{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/run-hook.cmd session-start",
            "timeout": 60,
            "statusMessage": "Loading Superpowers session hook"
          }
        ]
      }
    ]
  }
}
